{
  "color": {
    "dark": {
      "background": "#080810",
      "surface": "#0e0e18",
      "surfaceAlt": "#141420",
      "border": "#2a2a3a",
      "primary": "#00d4ff",
      "primaryMuted": "#0099bb",
      "success": "#00ff88",
      "warning": "#ffaa00",
      "danger": "#ff4466",
      "text": "#e4e4e7",
      "textMuted": "#6b6b80",
      "textDim": "#3a3a50"
    },
    "light": {
      "background": "#f8fafc",
      "surface": "#ffffff",
      "surfaceAlt": "#f1f5f9",
      "border": "#e2e8f0",
      "primary": "#2563eb",
      "primaryMuted": "#3b82f6",
      "success": "#16a34a",
      "warning": "#d97706",
      "danger": "#dc2626",
      "text": "#0f172a",
      "textMuted": "#64748b",
      "textDim": "#cbd5e1"
    }
  },
  "typography": {
    "fontFamily": { "main": "Inter, -apple-system, BlinkMacSystemFont, sans-serif", "mono": "JetBrains Mono, Menlo, monospace" },
    "fontSize": { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem", "3xl": "1.875rem", "4xl": "2.25rem" },
    "fontWeight": { "normal": "400", "medium": "500", "semibold": "600", "bold": "700", "extrabold": "800", "black": "900" }
  },
  "spacing": {
    "unit": "4px",
    "scale": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px" }
  },
  "radius": {
    "sm": "0.5rem", "md": "0.75rem", "lg": "1rem", "xl": "1.5rem", "2xl": "2rem"
  },
  "elevation": {
    "flat": "0 0 0 0 transparent",
    "low": "0 1px 2px rgba(0,0,0,0.3)",
    "mid": "0 4px 12px rgba(0,0,0,0.4)",
    "high": "0 8px 24px rgba(0,0,0,0.5)"
  },
  "shadow": {
    "sm": "0 1px 3px rgba(0,0,0,0.3)",
    "md": "0 4px 12px rgba(0,0,0,0.4)",
    "lg": "0 8px 24px rgba(0,0,0,0.5)"
  },
  "transition": {
    "fast": "100ms cubic-bezier(0.16, 1, 0.3, 1)",
    "normal": "200ms cubic-bezier(0.16, 1, 0.3, 1)",
    "slow": "350ms cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "border": {
    "thin": "1px solid var(--color-border)",
    "default": "1px solid var(--color-border)",
    "thick": "2px solid var(--color-border)"
  }
}