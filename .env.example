# Aleph-v2 Environment Configuration
# Copy this file to .env and fill in your values.

## Backend Configuration
PORT=8080
DATA_ROOT=./data/raw
KEY_ENCRYPTION_KEY=change_me_to_a_random_32_byte_hex_string

## LLM / AI Provider
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

## PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/aleph?sslmode=disable

## DuckDB Path
DUCKDB_PATH=./data/aleph.duckdb

## NLP Sidecar (Python gRPC)
NLP_ADDR=http://localhost:8001
# ALEPH_DUCKDB_PATH for the NLP sidecar (default: ./data/aleph.duckdb)
# GRPC_SERVER_ADDRESS=[::]:8001

## CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

## Rate Limiting (requests per minute)
RATE_LIMIT_CHAT=60
RATE_LIMIT_HEALTH=120
RATE_LIMIT_DEFAULT=100

## API Key Encryption (legacy; prefer KEY_ENCRYPTION_KEY)
ALEPH_API_KEY_SECRET_BACKEND=change_me_to_random_secret
ALEPH_API_KEY_SECRET=change_me_to_random_secret

## Logging
LOG_LEVEL=info

## Market Data APIs (optional)
# POLYMARKET_API_URL=https://clob.polymarket.com/markets
# METACULUS_API_URL=https://www.metaculus.com/api2/questions
# MARKET_REQUEST_TIMEOUT=10

## Environment
ENV=development

## Sentry Error Monitoring (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
