# Aleph-v2 Environment Configuration
# Copy this file to .env and fill in your values.
#
# SECRETS (use gosecrets, not .env):
#   KEY_ENCRYPTION_KEY  — set via: gosecrets set key_encryption_key "$(openssl rand -hex 32)"
#   JWT_SECRET           — set via: gosecrets set jwt.secret "$(openssl rand -hex 32)"
#   POSTGRES_DSN         — set via: gosecrets set postgres.dsn "postgres://..."
#   SMTP_PASSWORD        — set via: gosecrets set smtp.password "your-password"
#
# For CI, set GOSECRETS_ENV=ci and provide secrets as environment variables.
# For production, see deploy/docker-secrets-readme.md for full instructions.

## Non-sensitive configuration
PORT=8080
DATA_ROOT=./data/raw

## LLM / AI Provider
OLLAMA_BASE_URL=http://localhost:11434

## DuckDB
DUCKDB_PATH=./data/aleph.duckdb
DUCKDB_SCHEMA=main

## NLP Sidecar (Python gRPC)
NLP_ADDR=localhost:8001

## Embedding
EMBEDDING_MODEL=nomic-embed-text

## CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

## Rate Limiting (requests per minute)
RATE_LIMIT_CHAT=60
RATE_LIMIT_HEALTH=120
RATE_LIMIT_DEFAULT=100

## Backups
BACKUP_INTERVAL=24h
BACKUP_DIR=./data/backups/duckdb
BACKUP_KEEP=7

## Logging
LOG_LEVEL=info

## Limits
MAX_PROJECTS=50
MAX_AGENTS_PER_PROJECT=20
SLOW_QUERY_THRESHOLD_MS=500
LLM_TIMEOUT_SECONDS=30

## Environment
ENV=development
