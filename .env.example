# ── Aleph-v2 Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
#   cp .env.example .env
#
# Required for: docker compose up, local development

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# PostgreSQL password (used by the aleph-db service in docker-compose.yml)
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# PostgreSQL connection string (for system records & consistency)
# Host "db" resolves to the aleph-db container when using docker compose.
POSTGRES_DSN=postgres://postgres:CHANGE_ME_IN_PRODUCTION@db:5432/aleph?sslmode=disable

# ── API Keys ──────────────────────────────────────────────────────────────────

# API key for the backend (used for gRPC/RPC authentication between services)
ALEPH_API_KEY_SECRET_BACKEND=CHANGE_ME_IN_PRODUCTION

# API key for the NLP sidecar (used for NLP service authentication)
ALEPH_API_KEY_SECRET=CHANGE_ME_IN_PRODUCTION
