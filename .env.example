# Aleph-v2 Environment Configuration
# Copy to .env and fill in real values for production

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DSN=postgres://postgres:CHANGE_ME_IN_PRODUCTION@aleph-db:5432/aleph?sslmode=disable
ALEPH_API_KEY_SECRET_BACKEND=CHANGE_ME_IN_PRODUCTION
ALEPH_API_KEY_SECRET=CHANGE_ME_IN_PRODUCTION