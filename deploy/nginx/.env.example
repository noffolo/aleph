# Aleph-v2 NGINX SSL Certificate Paths
# --------------------------------------------------
# Copy this file and set real values before deploying nginx.conf.
# These env vars are substituted by nginx at startup when using envsubst.

# Path to full-chain certificate (PEM format)
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.example.com/fullchain.pem

# Path to private key
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.example.com/privkey.pem

# Optional: backend port override (default: 8080 in nginx.conf)
# BACKEND_PORT=8080

# --- Self-Signed Cert for Testing ---
# openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#   -keyout /etc/nginx/ssl/selfsigned.key \
#   -out /etc/nginx/ssl/selfsigned.crt \
#   -subj "/CN=localhost"
# Then set:
#   SSL_CERT_PATH=/etc/nginx/ssl/selfsigned.crt
#   SSL_KEY_PATH=/etc/nginx/ssl/selfsigned.key
